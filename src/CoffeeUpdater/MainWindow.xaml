<Window
        x:Class="CoffeeUpdater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Coffee Updater"
        Height="280"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="20,16,20,0">
            <TextBlock Text="Coffee Updater"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding Path=ClientVersion}"
                       FontSize="11"
                       Foreground="Gray"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Big status area -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Ellipse Width="12" Height="12"
                         Fill="{Binding Path=StatusDotColor}"
                         VerticalAlignment="Center"
                         Margin="0,0,8,0"/>
                <TextBlock Text="{Binding Path=StatusText}"
                           FontSize="16"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding Path=StatusDetail}"
                       FontSize="12"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"
                       Visibility="{Binding Path=StatusDetailVisibility}"/>
        </StackPanel>

        <!-- Separator -->
        <Separator Grid.Row="2" Margin="20,0,20,0"/>

        <!-- Path picker -->
        <StackPanel Grid.Row="3" Margin="20,10,20,16">
            <Label Content="WoW AddOns Folder" Padding="0,0,0,4" Foreground="Gray" FontSize="11"/>
            <DockPanel>
                <Button Content="Browse" DockPanel.Dock="Right" Width="60" Margin="8,0,0,0" Click="Browse_Clicked" FontSize="11"/>
                <TextBlock Text="{Binding Path=SelectedAddOnsPath, Mode=OneWay}"
                           FontSize="11"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </StackPanel>
    </Grid>
</Window>
